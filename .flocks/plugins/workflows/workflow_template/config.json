{
  "version": 1,
  "kind": "workflow.integration-config.template",
  "templateOnly": true,
  "visibility": "hidden",
  "workflow": {
    "id": "<workflow_id>",
    "name": "<workflow_name>",
    "source": "project"
  },
  "rendering": {
    "rule": "The publish page renders only configured publish and trigger modes.",
    "hideUnconfiguredModes": true,
    "secretsPolicy": "Do not store plaintext secrets; store secret references or configured booleans."
  },
  "publishTemplates": {
    "apiOnly": {
      "publish": {
        "type": "api_service",
        "enabled": false,
        "status": "stopped",
        "driver": "local",
        "apiKeyConfigured": false,
        "allowedActions": [
          "publish",
          "stop",
          "copyInvokeUrl",
          "rotateApiKey"
        ]
      },
      "triggers": []
    },
    "syslogOnly": {
      "publish": null,
      "triggers": [
        {
          "id": "syslog-default",
          "type": "syslog",
          "enabled": false,
          "status": "stopped",
          "source": {
            "host": "0.0.0.0",
            "port": 1514,
            "protocol": "udp",
            "framing": "line",
            "parser": "auto"
          },
          "mapping": {
            "input": "$.message",
            "remoteAddress": "$.remoteAddress",
            "receivedAt": "$.receivedAt"
          },
          "allowedActions": [
            "start",
            "stop"
          ]
        }
      ]
    },
    "kafkaOnly": {
      "publish": null,
      "triggers": [
        {
          "id": "kafka-default",
          "type": "kafka",
          "enabled": false,
          "status": "stopped",
          "source": {
            "bootstrapServers": [
              "localhost:9092"
            ],
            "topic": "<topic>",
            "groupId": "<group_id>",
            "autoOffsetReset": "latest"
          },
          "mapping": {
            "input": "$.value",
            "headers": "$.headers",
            "key": "$.key"
          },
          "allowedActions": [
            "start",
            "stop"
          ]
        }
      ]
    },
    "scheduleOnly": {
      "publish": null,
      "triggers": [
        {
          "id": "schedule-default",
          "type": "schedule",
          "enabled": false,
          "status": "stopped",
          "source": {
            "cron": "*/5 * * * *",
            "timezone": "Asia/Shanghai"
          },
          "mapping": {
            "input": {
              "trigger": "schedule"
            }
          },
          "allowedActions": [
            "start",
            "stop"
          ]
        }
      ]
    },
    "webhookOnly": {
      "publish": null,
      "triggers": [
        {
          "id": "webhook-default",
          "type": "webhook",
          "enabled": false,
          "status": "stopped",
          "source": {
            "method": "POST",
            "path": "/webhook/workflows/<workflow_id>/webhook-default"
          },
          "mapping": {
            "input": "$.body"
          },
          "auth": {
            "type": "api_key",
            "apiKeyConfigured": false
          },
          "allowedActions": [
            "enable",
            "disable",
            "copyWebhookUrl"
          ]
        }
      ]
    }
  },
  "exampleActiveConfig": {
    "publish": null,
    "triggers": [
      {
        "id": "syslog-default",
        "type": "syslog",
        "enabled": false,
        "status": "stopped",
        "source": {
          "host": "0.0.0.0",
          "port": 1514,
          "protocol": "udp",
          "framing": "line",
          "parser": "auto"
        },
        "mapping": {
          "input": "$.message"
        },
        "allowedActions": [
          "start",
          "stop"
        ]
      }
    ]
  }
}
