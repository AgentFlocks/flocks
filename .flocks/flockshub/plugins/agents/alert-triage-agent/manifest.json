    "network": true,
    "shell": false,
    "filesystem": "read"
  },
  "risk": {
    "level": "medium",
    "reasons": [
      "May use network search tools for enrichment."
    ]
  },
  "entrypoints": [
    "agent.yaml",
    "prompt.md"
  ],
  "checksums": {}
}
