{
  "schemaVersion": "hub.plugin.v1",
  "id": "alert-triage-agent",
  "type": "agent",
  "name": "Alert Triage Agent",
  "description": "面向安全告警分诊的轻量子 Agent，适合把原始告警转为可执行研判结论。",
  "version": "1.0.0",
  "author": "Flocks Team",
  "license": "MIT",
  "homepage": "",
  "category": "workflow-automation",
  "tags": [
    "siem"
  ],
  "useCases": [
    "alert-triage"
  ],
  "domains": [
    "security-ops"
  ],
  "capabilities": [
    "llm-agent"
  ],
