{
  "schemaVersion": "hub.plugin.v1",
  "id": "soc-workspace",
  "type": "component",
  "name": "SOC Workspace Component",
  "description": "Composite installer for the Flocks SOC workspace: pages, tools, denoise workflow, and triage workflow.",
